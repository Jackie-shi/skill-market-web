generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  bio           String?
  githubUrl     String?
  websiteUrl    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Stripe
  stripeCustomerId       String? @unique
  stripeConnectId        String? @unique
  stripeConnectOnboarded Boolean @default(false)

  accounts        Account[]
  sessions        Session[]
  publishedSkills PublishedSkill[]
  purchases       Purchase[]
  reviews         Review[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PublishedSkill {
  id              String    @id @default(cuid())
  name            String    @unique
  displayName     String
  description     String
  longDescription String?
  version         String
  category        String
  price           Float     @default(0)
  currency        String    @default("USD")
  pricingModel    String    @default("free")
  platforms       String // JSON array as string
  osTargets       String? // JSON array as string
  keywords        String? // JSON array as string
  license         String?
  repository      String?
  downloads       Int       @default(0)
  status          String    @default("pending") // pending, approved, rejected
  reviewNote      String?
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  purchases Purchase[]
  reviews   Review[]
  versions  SkillVersion[]

  // Cached rating
  averageRating Float @default(0)
  reviewCount   Int   @default(0)
}

model Review {
  id        String   @id @default(cuid())
  rating    Int // 1-5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId  String
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId String
  skill   PublishedSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId]) // one review per user per skill
  @@index([skillId])
}

model SkillVersion {
  id        String   @id @default(cuid())
  version   String
  changelog String?
  files     String? // JSON: list of changed files or metadata
  createdAt DateTime @default(now())

  skillId String
  skill   PublishedSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, version])
  @@index([skillId])
}

model Purchase {
  id        String   @id @default(cuid())
  amount    Float
  currency  String   @default("USD")
  status    String   @default("pending") // pending, completed, failed, refunded
  createdAt DateTime @default(now())

  // Stripe
  stripeSessionId     String? @unique
  stripePaymentIntent String?
  platformFee         Float? // 15% platform cut
  creatorPayout       Float? // 85% creator share

  userId  String
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId String
  skill   PublishedSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)
}
