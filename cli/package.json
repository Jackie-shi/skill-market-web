{
  "name": "skillmarket",
  "version": "1.0.0",
  "description": "CLI tool for Skill Market — discover, install, and manage AI Skills",
  "type": "module",
  "bin": {
    "skillmarket": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx src/index.ts",
    "test": "node --test dist/index.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["ai", "skills", "cli", "claude-code", "openclaw", "cursor", "windsurf"],
  "author": "Skill Market",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jackie-shi/skill-market-web"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "tar": "^7.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
